generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Hymn {
  id         String   @id @default(cuid())
  title      String   @unique
  author     String
  lyrics     String   @db.Text
  imagePaths String[] @default([])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([title])
}
